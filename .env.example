# Postgres connection used by the running app (pooled / PgBouncer-compatible).
# Neon: use the "pooled connection" string from your project dashboard.
DATABASE_URL="postgresql://user:password@host/dbname?sslmode=require&pgbouncer=true&connection_limit=1"

# Direct (unpooled) Postgres connection, used only by `prisma migrate`.
# Neon: use the "direct connection" string from your project dashboard.
DIRECT_URL="postgresql://user:password@host/dbname?sslmode=require"

# Shared passphrase for the leadership dashboard gate.
HPCI_ADMIN_PASSPHRASE="change-me"

# Random 32+ byte secret used to sign/encrypt the admin session cookie.
# Generate one with: openssl rand -base64 32
HPCI_SESSION_SECRET="change-me-to-a-long-random-string"
